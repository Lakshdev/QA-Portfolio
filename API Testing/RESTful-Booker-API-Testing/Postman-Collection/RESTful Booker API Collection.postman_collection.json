      "item": [
        {
          "name": "TC-API-003 - Create New Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking ID is generated\", function () {\r",
                  "    pm.expect(responseData.bookingid).to.exist;\r",
                  "    pm.expect(responseData.bookingid).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Firstname is correct\", function () {\r",
                  "    pm.expect(responseData.booking.firstname)\r",
                  "        .to.eql(pm.environment.get(\"firstname\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Lastname is correct\", function () {\r",
                  "    pm.expect(responseData.booking.lastname)\r",
                  "        .to.eql(pm.environment.get(\"lastname\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Total price is correct\", function () {\r",
                  "    pm.expect(responseData.booking.totalprice).to.eql(1500);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Deposit paid value is correct\", function () {\r",
                  "    pm.expect(responseData.booking.depositpaid).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking dates are correct\", function () {\r",
                  "    pm.expect(responseData.booking.bookingdates.checkin)\r",
                  "        .to.eql(\"2026-08-01\");\r",
                  "\r",
                  "    pm.expect(responseData.booking.bookingdates.checkout)\r",
                  "        .to.eql(\"2026-08-05\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Additional needs is Breakfast\", function () {\r",
                  "    pm.expect(responseData.booking.additionalneeds)\r",
                  "        .to.eql(\"Breakfast\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is below 2000 ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"bookingId\", responseData.bookingid);\r",
                  "\r",
                  "console.log(\"Created Booking ID: \" + responseData.bookingid);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
