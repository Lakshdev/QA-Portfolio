    {
      "name": "03 - Booking - GET",
      "item": [
        {
          "name": "TC-API-005 - Get Booking by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Firstname is correct\", function () {\r",
                  "    pm.expect(responseData.firstname)\r",
                  "        .to.eql(pm.environment.get(\"firstname\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Lastname is correct\", function () {\r",
                  "    pm.expect(responseData.lastname)\r",
                  "        .to.eql(pm.environment.get(\"lastname\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Deposit Paid is true\", function () {\r",
                  "    pm.expect(responseData.depositpaid)\r",
                  "        .to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Total Price is correct\", function () {\r",
                  "    pm.expect(responseData.totalprice)\r",
                  "        .to.eql(1500);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Additional Needs is Breakfast\", function () {\r",
                  "    pm.expect(responseData.additionalneeds)\r",
                  "        .to.eql(\"Breakfast\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check-in date is correct\", function () {\r",
                  "    pm.expect(responseData.bookingdates.checkin)\r",
                  "        .to.eql(\"2026-08-01\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check-out date is correct\", function () {\r",
                  "    pm.expect(responseData.bookingdates.checkout)\r",
                  "        .to.eql(\"2026-08-05\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time below 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Status code should be 404\", function () {\r",
                  "    pm.response.to.have.status(404);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
